{
  "name": "sr-launcher-v2",
  "productName": "Slavonska Ravnica",
  "version": "2.0.0",
  "description": "SR Launcher V2 - Farming Simulator 25 Multiplayer Launcher",
  "main": "out/main/index.js",
  "author": "Slavonska Ravnica",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || true"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/yauzl": "^3.4.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "basic-ftp": "^5.0.5",
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.1.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.3",
    "ssh2-sftp-client": "^9.1.0",
    "yauzl": "^3.4.0",
    "zustand": "^4.5.0"
  }
}
