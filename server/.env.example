# Railway environment variables (postavi ih u Railway dashboard > Variables)

# Discord OAuth2 aplikacija
DISCORD_CLIENT_ID=tvoj_client_id
DISCORD_CLIENT_SECRET=tvoj_client_secret

# Discord server (Guild) i potrebna rola
DISCORD_GUILD_ID=tvoj_guild_id
DISCORD_REQUIRED_ROLE_ID=tvoj_role_id

# Tajni ključ za potpisivanje sesija (bilo koji dugačak random string)
JWT_SECRET=promijeni_me_u_dugi_random_string

# Javni URL ovog backenda (Railway ti ga da nakon deploya), BEZ kose crte na kraju
# Primjer: https://sr-launcher-backend-production.up.railway.app
PUBLIC_URL=https://tvoj-projekt.up.railway.app
